    {
      "parameters": {
        "jsCode": "const data = items[0].json;\nconst isCallbackQuery = !!data.callback_query;\nconst isMessage = !!data.message;\n\nif (isCallbackQuery) {\n  const cbData = data.callback_query.data || '';\n  const match = cbData.match(/^confirm_(.+)_(yes|no)$/);\n  if (match) {\n    return [{ json: {\n      type: 'confirmation',\n      action: match[2],\n      booking_number: match[1],\n      chat_id: data.callback_query.message.chat.id,\n      message_id: data.callback_query.message.message_id,\n      from_user: data.callback_query.from.first_name,\n      callback_query_id: data.callback_query.id\n    }}];\n  }\n  if (cbData.startsWith('payment_')) {\n    const parts = cbData.split('_');\n    const method = parts[parts.length - 1];\n    const bn = parts.slice(1, parts.length - 1).join('_');\n    return [{ json: {\n      type: 'payment',\n      method: method === 'cash' ? 'Cash' : 'Bank transfer',\n      booking_number: bn,\n      chat_id: data.callback_query.message.chat.id,\n      callback_query_id: data.callback_query.id\n    }}];\n  }\n}\n\nif (isMessage) {\n  const text = (data.message.text || '').trim();\n  const chatId = data.message.chat.id;\n  if (text === '/dashboard') {\n    return [{ json: { type: 'dashboard', chat_id: chatId }}];\n  }\n  if (text.startsWith('/cash ')) {\n    return [{ json: { type: 'cash', guide_name: text.replace('/cash ', '').trim(), chat_id: chatId }}];\n  }\n  if (text.startsWith('/collected ')) {\n    return [{ json: { type: 'collected', guide_name: text.replace('/collected ', '').trim(), chat_id: chatId }}];\n  }\n  return [{ json: { type: 'message', text, chat_id: chatId }}];\n}\n\nreturn [{ json: { type: 'unknown' }}];"
      },
