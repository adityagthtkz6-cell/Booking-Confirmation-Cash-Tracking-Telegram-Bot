    {
      "parameters": {
        "jsCode": "const guideName = items[0].json.guide_name || '';\nconst chatId = items[0].json.chat_id;\n\nlet total = 0, count = 0;\nfor (const item of items) {\n  const row = item.json;\n  const guide = (row['Guide name'] || '').trim().toLowerCase();\n  const confirmed = (row['Confirmed'] || '').trim();\n  const payment = (row['Payment method'] || '').trim().toLowerCase();\n  const collected = (row['Collected by cashier'] || '').trim().toLowerCase();\n  const amount = parseFloat(row['Amount collected'] || 0) || 0;\n\n  if (guide === guideName.toLowerCase() && confirmed === 'Yes' && payment === 'cash' && (!collected || collected === 'no')) {\n    total += amount;\n    count++;\n  }\n}\n\nconst msg = total > 0\n  ? `💰 *${guideName}* currently holds *QAR ${total.toLocaleString()}* in cash (${count} booking${count !== 1 ? 's' : ''}).`\n  : `ℹ️ *${guideName}* has no uncollected cash.`;\n\nreturn [{ json: { message: msg, chat_id: chatId }}];"
      },
