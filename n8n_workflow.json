    {
      "parameters": {
        "jsCode": "const today = new Date();\nconst tomorrow = new Date(today);\ntomorrow.setDate(today.getDate() + 1);\nconst tomorrowStr = tomorrow.toISOString().split('T')[0];\n\nconst grouped = {};\nfor (const item of items) {\n  const row = item.json;\n  const apptDate = (row['Appointment Date'] || '').substring(0, 10);\n  const status = (row['appointment_status'] || '').trim().toLowerCase();\n  if (apptDate !== tomorrowStr || status !== 'approved') continue;\n\n  const service = (row['service_name'] || '').trim();\n  const apptId = String(row['Appointment ID'] || '');\n  const customerName = (row['Customer Name'] || '').trim();\n  const amount = parseFloat(row['app_sum_price'] || 0) || 0;\n  const adults = parseInt(row['Adult_Cnt'] || 0) || 0;\n  const kids = parseInt(row['Kids_Cnt'] || 0) || 0;\n\n  if (!grouped[service]) {\n    grouped[service] = { service, date: tomorrowStr, adults: 0, kids: 0, amount: 0, ticketIds: [], customerNames: [] };\n  }\n  grouped[service].adults += adults;\n  grouped[service].kids += kids;\n  grouped[service].amount += amount;\n  if (apptId) grouped[service].ticketIds.push(apptId);\n  if (customerName) grouped[service].customerNames.push(customerName);\n}\n\nreturn Object.values(grouped).map(g => ({ json: g }));"
      },
      "id": "sync-booknetic",
      "name": "Sync & Group Booknetic Bookings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 160]
    },

