    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().split('T')[0];\nconst thisMonth = today.substring(0, 7);\n\nlet todayConfirmed = 0, todayNoShow = 0, todayRevenue = 0;\nlet monthConfirmed = 0, monthNoShow = 0, monthRevenue = 0, monthCash = 0, monthBank = 0;\nlet allConfirmed = 0, allRevenue = 0;\n\nfor (const item of items) {\n  const row = item.json;\n  const bd = (row['Booking date'] || '').substring(0, 10);\n  const confirmed = (row['Confirmed'] || '').trim();\n  const amount = parseFloat(row['Amount collected'] || 0) || 0;\n  const payment = (row['Payment method'] || '').toLowerCase();\n\n  if (confirmed === 'Yes') {\n    allConfirmed++;\n    allRevenue += amount;\n    if (bd === today) { todayConfirmed++; todayRevenue += amount; }\n    if (bd.startsWith(thisMonth)) {\n      monthConfirmed++; monthRevenue += amount;\n      if (payment === 'cash') monthCash += amount;\n      else monthBank += amount;\n    }\n  }\n  if (confirmed === 'No-show') {\n    if (bd === today) todayNoShow++;\n    if (bd.startsWith(thisMonth)) monthNoShow++;\n  }\n}\n\nconst msg = `📊 *Booking Dashboard*\\n\\n` +\n  `📅 *Today's Snapshot*\\n` +\n  `✅ Confirmed: ${todayConfirmed}\\n` +\n  `❌ No-shows: ${todayNoShow}\\n` +\n  `💰 Revenue: QAR ${todayRevenue.toLocaleString()}\\n\\n` +\n  `📆 *This Month*\\n` +\n  `✅ Confirmed: ${monthConfirmed}\\n` +\n  `❌ No-shows: ${monthNoShow}\\n` +\n  `💰 Total Revenue: QAR ${monthRevenue.toLocaleString()}\\n` +\n  `💵 Cash: QAR ${monthCash.toLocaleString()} | 🏦 Bank: QAR ${monthBank.toLocaleString()}\\n\\n` +\n  `📈 *All Time*\\n` +\n  `✅ Confirmed: ${allConfirmed}\\n` +\n  `💰 Total Revenue: QAR ${allRevenue.toLocaleString()}`;\n\nreturn [{ json: { message: msg, chat_id: items[0].json.chat_id || 'UNKNOWN' }}];"
      },
      "id": "build-dashboard",
      "name": "Calculate Dashboard Stats",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
