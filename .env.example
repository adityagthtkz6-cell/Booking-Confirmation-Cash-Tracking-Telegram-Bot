# ── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Group chat ID (negative integer for Telegram groups, e.g. -1001234567890)
TELEGRAM_GROUP_ID=-1001234567890

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The long ID in the sheet URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=your_spreadsheet_id_here

# Tab names — change only if your sheet uses different names
BOOKINGS_SHEET_NAME=Bookings
COLLECTIONS_SHEET_NAME=Cash Collections Log

# ── Google Drive ──────────────────────────────────────────────────────────────
# ID of the parent Drive folder where a /Receipts/ subfolder will be created
DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── Google Service Account ────────────────────────────────────────────────────
# EITHER a file path to the JSON key, OR the raw JSON content inline.
# Option A — file path:
GOOGLE_CREDENTIALS_FILE=credentials.json
# Option B — inline JSON (useful for Railway/Heroku where file storage is limited):
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...",...}

# ── Access Control ────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to answer booking prompts
GUIDE_USER_IDS=123456789,987654321

# Comma-separated Telegram user IDs allowed to run cashier commands
CASHIER_USER_IDS=111222333

# ── Scheduler ─────────────────────────────────────────────────────────────────
# 24-hour HH:MM — time the daily confirmation job fires
TRIGGER_TIME=08:00

# IANA timezone name — must match where the guides operate
TIMEZONE=Asia/Qatar

# ── Display ───────────────────────────────────────────────────────────────────
CURRENCY=QAR
