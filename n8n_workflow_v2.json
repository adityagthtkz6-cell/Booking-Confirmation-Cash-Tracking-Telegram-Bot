    {
      "parameters": {
        "jsCode": "const update = $input.first().json;\nlet route = 'unknown';\nlet payload = {};\nif (update.callback_query) {\n  const cb = update.callback_query.data || '';\n  const chatId = String(update.callback_query.message.chat.id);\n  const msgId = update.callback_query.message.message_id;\n  if (cb.startsWith('confirm_')) {\n    const lastIdx = cb.lastIndexOf('_');\n    const answer = cb.substring(lastIdx + 1);\n    const bookingNum = cb.substring('confirm_'.length, lastIdx);\n    route = answer === 'yes' ? 'YES' : 'NO';\n    payload = { booking_number: bookingNum, chat_id: chatId, message_id: msgId, callback_id: update.callback_query.id };\n  }\n} else if (update.message) {\n  const text = (update.message.text || '').trim();\n  const chatId = String(update.message.chat.id);\n  if (text === '/sync') { route = 'SYNC'; payload = { chat_id: chatId }; }\n  else if (text === '/dashboard') { route = 'DASHBOARD'; payload = { chat_id: chatId }; }\n  else if (text.toLowerCase().startsWith('/collected')) {\n    const guide = text.split(' ').slice(1).join(' ').trim();\n    route = 'COLLECTED'; payload = { chat_id: chatId, guide_name: guide || 'Guide' };\n  } else if (text.toLowerCase().startsWith('/data')) {\n    const parts = text.split(' ');\n    route = 'DATA_ENTRY';\n    payload = { chat_id: chatId, booking_number: parts[1]||'', adults: parseInt(parts[2])||0, kids: parseInt(parts[3])||0, amount: parseFloat(parts[4])||0, payment: parts[5]||'Cash' };\n  }\n}\nreturn [{ json: { route, ...payload } }];"
      },
