      "parameters": {
        "jsCode": "const today = new Date();\nconst tom = new Date(today);\ntom.setDate(today.getDate() + 1);\nconst tomStr = tom.toISOString().split('T')[0];\nconst grouped = {};\nfor (const item of items) {\n  const r = item.json;\n  const dt = (r['Appointment Date'] || '').substring(0, 10);\n  const st = (r['appointment_status'] || '').trim().toLowerCase();\n  if (dt !== tomStr || st !== 'approved') continue;\n  const svc = (r['service_name'] || '').trim();\n  const id = String(r['Appointment ID'] || '');\n  const name = (r['Customer Name'] || '').trim();\n  const amt = parseFloat(r['app_sum_price'] || 0) || 0;\n  const adults = parseInt(r['Adult_Cnt'] || 0) || 0;\n  const kids = parseInt(r['Kids_Cnt'] || 0) || 0;\n  const key = tomStr + '__' + svc;\n  if (!grouped[key]) grouped[key] = {booking_date:tomStr, tour_name:svc, expected_adults:0, expected_kids:0, expected_amount:0, ticket_ids:[], customer_names:[]};\n  grouped[key].expected_adults += adults;\n  grouped[key].expected_kids += kids;\n  grouped[key].expected_amount += amt;\n  if (id) grouped[key].ticket_ids.push(id);\n  if (name && !grouped[key].customer_names.includes(name)) grouped[key].customer_names.push(name);\n}\nconst result = Object.values(grouped).map(g => ({json:{...g, ticket_ids_str:g.ticket_ids.join(', '), customer_names_str:g.customer_names.join(', ')}}));\nreturn result.length ? result : [{json:{no_bookings:true}}];"
      },
