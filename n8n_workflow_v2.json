    {
      "parameters": {
        "jsCode": "const rows = items.map(i => i.json);\nconst thisMonth = new Date().toISOString().substring(0, 7);\nlet total=0, confirmed=0, noshow=0, pending=0, totalRev=0, monthRev=0, cashRev=0;\nfor (const r of rows) {\n  total++;\n  const st = (r['Confirmed']||'').trim();\n  const amt = parseFloat(r['Amount collected']||0)||0;\n  const bd = String(r['Booking date']||'').substring(0,7);\n  const pay = (r['Payment method']||'').toLowerCase();\n  if (st==='Yes') { confirmed++; totalRev+=amt; if(bd===thisMonth) monthRev+=amt; if(pay==='cash') cashRev+=amt; }\n  else if (st==='No-show') noshow++;\n  else pending++;\n}\nconst chatId = $('Route Switch').first().json.chat_id;\nreturn [{json:{chat_id:chatId, total, confirmed, noshow, pending, totalRev:totalRev.toFixed(2), monthRev:monthRev.toFixed(2), cashRev:cashRev.toFixed(2)}}];"
      },
