      "parameters": {
        "jsCode": "const guideName = ($('Route Switch').first().json.guide_name || '').toLowerCase();\nconst chatId = $('Route Switch').first().json.chat_id;\nconst guideFull = $('Route Switch').first().json.guide_name;\nlet total = 0;\nfor (const item of items) {\n  const r = item.json;\n  const guide = (r['Guide name']||'').toLowerCase();\n  const st = (r['Confirmed']||'').trim();\n  const pay = (r['Payment method']||'').toLowerCase();\n  const collectedBy = (r['Collected by cashier']||'').trim();\n  if (guide.includes(guideName) && st==='Yes' && pay==='cash' && !collectedBy) {\n    total += parseFloat(r['Amount collected']||0)||0;\n  }\n}\nconst date = new Date().toISOString().split('T')[0];\nreturn [{json:{chat_id:chatId, guide_name:guideFull, total_cash:total.toFixed(2), date}}];"
      },
